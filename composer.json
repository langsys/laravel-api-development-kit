{
    "name": "langsys/laravel-api-development-kit",
    "description": "A comprehensive Laravel API development toolkit with DTO processing, structured exception handling, resource filtering/ordering, and API key authentication.",
    "keywords": ["laravel", "api", "dto", "exception-handling", "filtering", "ordering", "api-key"],
    "license": "MIT",
    "authors": [
        {
            "name": "Langsys",
            "email": "dev@langsys.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "spatie/laravel-data": "^3.0|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Langsys\\ApiKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Langsys\\ApiKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Langsys\\ApiKit\\ApiKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
